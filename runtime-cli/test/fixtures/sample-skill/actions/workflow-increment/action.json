{
  "action_id": "workflow.increment",
  "version": "1.0.0",
  "kind": "composite",
  "title": "Increment",
  "description": "Increment a number by one via internal helper",
  "input_schema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "number"
      }
    },
    "required": ["value"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "number"
      }
    },
    "required": ["value"],
    "additionalProperties": false
  },
  "visibility": "public",
  "side_effect": "none",
  "idempotent": true,
  "steps": [
    {
      "id": "addOne",
      "action": "math.add-one",
      "with": {
        "value": "$input.value"
      }
    }
  ]
}

