{
  "action_id": "workflow.external",
  "kind": "composite",
  "title": "Workflow External",
  "description": "Use a fully-qualified global action reference",
  "input_schema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "number"
      }
    },
    "required": ["value"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "number"
      }
    },
    "required": ["value"],
    "additionalProperties": false
  },
  "idempotent": true,
  "steps": [
    {
      "id": "addOne",
      "action": "cli://math/add-one",
      "with": {
        "value": "$input.value"
      }
    }
  ],
  "returns": {
    "value": "$steps.addOne.output.value"
  }
}
